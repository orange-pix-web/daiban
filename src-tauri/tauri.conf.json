{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "我的待办",
  "version": "0.1.0",
  "identifier": "com.orange.daiban",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "我的笔记待办与日历",
        "width": 560,
        "height": 520,
        "minWidth": 420,
        "minHeight": 460,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "shadow": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "本地笔记、待办与日历",
    "longDescription": "支持本地持久化、键盘操作、笔记、待办和日历管理的桌面应用。",
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "languages": [
          "SimpChinese"
        ]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
